{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "0.1.0",
  "description": "Lucid Web Craftsman — React + Vite + TypeScript storefront with shadcn/ui, Tailwind CSS, and E2E testing.",
  "license": "UNLICENSED",
  "author": {
    "name": "benmed00",
    "email": "benyakoub.dev@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/benmed00/lucid-web-craftsman.git"
  },
  "bugs": {
    "url": "https://github.com/benmed00/lucid-web-craftsman/issues"
  },
  "homepage": "https://github.com/benmed00/lucid-web-craftsman",
  "keywords": [
    "react",
    "vite",
    "typescript",
    "tailwindcss",
    "shadcn-ui",
    "zustand",
    "supabase",
    "cypress"
  ],
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.9",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:e2e": "cross-env VITE_E2E=1 vite",
    "serve": "node backend/server.cjs",
    "start:api": "node backend/server.cjs",
    "build": "vite build",
    "predeploy": "vite build",
    "deploy": "gh-pages -d dist",
    "build:prod": "vite build --mode production",
    "build:dev": "vite build --mode development",
    "lint": "eslint . --max-warnings 9999",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,html,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,html,css}\"",
    "test": "vitest",
    "test:ui": "vitest --ui --api.host 127.0.0.1 --api.port 24678",
    "deno:check:create-payment": "deno check supabase/functions/create-payment/index.ts --config supabase/functions/deno.json",
    "deno:lint:create-payment": "deno lint supabase/functions/create-payment/ --config supabase/functions/deno.json",
    "test:create-payment": "deno test supabase/functions/create-payment/ --config supabase/functions/deno.json --allow-env",
    "deno:check:create-admin-user": "deno check supabase/functions/create-admin-user/index.ts --config supabase/functions/deno.json",
    "deno:lint:create-admin-user": "deno lint supabase/functions/create-admin-user/ --config supabase/functions/deno.json",
    "test:create-admin-user": "deno test --allow-env --config supabase/functions/deno.json supabase/functions/create-admin-user/handler_test.ts",
    "verify:create-admin-user": "pnpm run deno:check:create-admin-user && pnpm run deno:lint:create-admin-user && pnpm run test:create-admin-user",
    "verify:create-payment": "pnpm run deno:check:create-payment && pnpm run deno:lint:create-payment && deno test supabase/functions/create-payment/ --config supabase/functions/deno.json --allow-env",
    "deploy:functions:create-payment": "supabase functions deploy create-payment",
    "deploy:functions:payment-success": "supabase functions deploy order-lookup && supabase functions deploy stripe-session-display && supabase functions deploy verify-payment",
    "deploy:functions:stripe-return": "pnpm run deploy:functions:payment-success && supabase functions deploy send-order-confirmation && supabase functions deploy stripe-webhook",
    "deploy:functions:monitor-payment-events": "supabase functions deploy monitor-payment-events",
    "deploy:functions:order-confirmation-lookup": "supabase functions deploy order-confirmation-lookup",
    "deploy:functions:get-order-by-token": "supabase functions deploy get-order-by-token",
    "deploy:functions:reconcile-payment": "supabase functions deploy reconcile-payment",
    "deploy:pricing-snapshot-and-monitoring": "supabase functions deploy stripe-webhook && supabase functions deploy verify-payment && supabase functions deploy reconcile-payment && supabase functions deploy send-order-confirmation && supabase functions deploy order-confirmation-lookup && supabase functions deploy get-order-by-token && supabase functions deploy monitor-payment-events",
    "check:edge-functions:bundling": "node scripts/check-edge-functions-bundling.mjs --no-deno",
    "check:edge-functions:bundling:full": "node scripts/check-edge-functions-bundling.mjs",
    "check:edge-functions:bundling:report": "node scripts/check-edge-functions-bundling.mjs --no-deno --report-json reports/edge-functions-bundling.json --report-html reports/edge-functions-bundling.html --report-compact-json reports/edge-functions-bundling-errors.json",
    "check:edge-functions:bundling:ci": "node scripts/check-edge-functions-bundling.mjs --no-deno --compact-json",
    "deploy:functions:all": "pnpm run check:edge-functions:bundling && node scripts/deploy-all-supabase-functions.mjs",
    "supabase:db:query": "npx --yes supabase@2.90.0 db query --linked --agent=no",
    "supabase:migration:list": "npx --yes supabase@2.90.0 migration list --linked --agent=no -o pretty",
    "supabase:migration:diff": "node scripts/migration-local-remote-diff.mjs",
    "verify:guest-token-rpc": "node scripts/verify-guest-token-rpc.mjs",
    "supabase:types:gen": "node scripts/supabase-gen-types.mjs",
    "test:edge-functions": "vitest run src/tests/edge-functions.test.ts src/tests/edge-functions-carrier-mappings.test.ts",
    "test:unit": "vitest run --exclude \"**/rls-e2e.test.ts\" --exclude \"**/rls-quick-validation.test.ts\"",
    "test:pricing-snapshot": "node scripts/assert-deno-v2.mjs && deno test --allow-env --allow-read=. --no-check --config supabase/functions/deno.json supabase/functions/_shared/pricing-snapshot_test.ts supabase/functions/_shared/pricing_snapshot_golden_test.ts supabase/functions/_shared/pricing_snapshot_extended_test.ts supabase/functions/_shared/persist-pricing-snapshot_test.ts supabase/functions/_shared/confirm-order_test.ts supabase/functions/stripe-webhook/lib/pricing-snapshot_test.ts supabase/functions/send-order-confirmation/_lib/email-pricing-from-db_test.ts && vitest run src/lib/checkout/pricingSnapshot.test.ts",
    "test:pricing-snapshot:deno": "node scripts/assert-deno-v2.mjs && deno test --allow-env --allow-read=. --no-check --config supabase/functions/deno.json supabase/functions/_shared/pricing-snapshot_test.ts supabase/functions/_shared/pricing_snapshot_golden_test.ts supabase/functions/_shared/pricing_snapshot_extended_test.ts supabase/functions/_shared/persist-pricing-snapshot_test.ts supabase/functions/_shared/confirm-order_test.ts supabase/functions/stripe-webhook/lib/pricing-snapshot_test.ts supabase/functions/send-order-confirmation/_lib/email-pricing-from-db_test.ts",
    "verify:pricing-snapshot:offline": "node scripts/verify-pricing-snapshot-offline.mjs",
    "test:pricing-snapshot:offline-meta": "node scripts/assert-deno-v2.mjs && deno test --allow-run=deno --allow-env --allow-read=. --no-check --config supabase/functions/deno.json supabase/functions/_shared/pricing_snapshot_offline_meta_test.ts",
    "coverage": "vitest run --coverage",
    "e2e:open": "cypress open",
    "e2e:run": "cypress run",
    "e2e:smoke": "cypress run --env grep=@smoke",
    "e2e:regression": "cypress run --env grep=@regression",
    "e2e:enterprise": "cypress run --spec 'cypress/e2e/enterprise_full_platform_spec.js'",
    "e2e:preview": "cross-env CYPRESS_BASE_URL=https://deploy-preview-4--benyakoub.netlify.app cypress run --spec \"cypress/e2e/enterprise_full_platform_spec.js\"",
    "e2e:checkout": "start-server-and-test \"pnpm run start:api\" http-get://localhost:3001 \"pnpm run dev:e2e\" http-get://127.0.0.1:8080/contact \"cypress run --spec cypress/e2e/checkout_flow_spec.js,cypress/e2e/checkout_persistence_spec.js,cypress/e2e/checkout_db_hydration_spec.ts\"",
    "e2e:contact": "start-server-and-test \"pnpm run start:api\" http-get://localhost:3001 \"pnpm run dev:e2e\" http-get://127.0.0.1:8080/contact \"cypress run --spec cypress/e2e/contact_form_spec.js\"",
    "e2e:ci": "start-server-and-test \"pnpm run start:api\" http-get://localhost:3001 \"pnpm run dev:e2e\" http-get://127.0.0.1:8080/contact \"cypress run\"",
    "e2e:ci:shard": "node scripts/cypress-e2e-shard.mjs",
    "e2e:ci:smoke": "start-server-and-test \"pnpm run start:api\" http-get://localhost:3001 \"pnpm run dev:e2e\" http-get://127.0.0.1:8080/contact \"cypress run --env grep=@smoke\"",
    "type:check": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p cypress/tsconfig.json",
    "browserslist:update": "pnpm update caniuse-lite browserslist",
    "lint:e2e-port": "node scripts/lint-e2e-port.mjs",
    "validate": "pnpm run lint && pnpm run lint:e2e-port && pnpm run format:check && pnpm run type:check && pnpm run check:edge-functions:bundling && pnpm run test -- --run",
    "openapi:edge-functions": "node scripts/openapi-edge-functions.mjs",
    "openapi:edge-functions:check": "node scripts/openapi-edge-functions-check.mjs",
    "postman:collection": "node scripts/build-postman-collection.mjs",
    "postman:collection:check": "node scripts/postman-collection-check.mjs",
    "api:artifacts": "pnpm run openapi:edge-functions && pnpm run postman:collection",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-aspect-ratio": "^1.1.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-context-menu": "^2.2.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-hover-card": "^1.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-menubar": "^1.1.1",
    "@radix-ui/react-navigation-menu": "^1.2.0",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-radio-group": "^1.2.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-toggle": "^1.1.0",
    "@radix-ui/react-toggle-group": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@stripe/stripe-js": "^2.3.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "@tanstack/react-query": "^5.56.2",
    "@tanstack/react-query-devtools": "^5.76.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.21",
    "@uiw/react-md-editor": "^4.0.11",
    "axios": "^1.9.0",
    "bcryptjs": "^2.4.3",
    "caniuse-lite": "^1.0.30001718",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^3.6.0",
    "dompurify": "^3.2.6",
    "embla-carousel-react": "^8.3.0",
    "i18next": "^25.7.4",
    "i18next-browser-languagedetector": "^8.2.0",
    "input-otp": "^1.2.4",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.462.0",
    "next-themes": "^0.3.0",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^6.0.0",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.53.0",
    "react-i18next": "^16.5.3",
    "react-leaflet": "^4.2.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.3",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.12.7",
    "rollup": "^4.60.2",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^0.9.3",
    "web-vitals": "^4.2.4",
    "zod": "^3.23.8",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@cypress/grep": "^5.1.0",
    "@eslint/js": "^9.27.0",
    "@tailwindcss/typography": "^0.5.15",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^22.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.5.0",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "cypress": "^15.9.0",
    "cypress-axe": "^1.7.0",
    "cypress-real-events": "^1.15.0",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "eslint-plugin-unused-imports": "^4.4.1",
    "gh-pages": "^6.3.0",
    "globals": "^15.9.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lovable-tagger": "^1.1.7",
    "postcss": "^8.4.47",
    "prettier": "^3.5.3",
    "start-server-and-test": "^2.1.5",
    "tailwindcss": "^3.4.11",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^5.4.1",
    "vite-plugin-gh-pages": "^1.0.1",
    "vitest": "^4.0.18"
  },
  "workspaces": [
    ".",
    "backend"
  ]
