# Copy to `.env` for local development.
# Docs: docs/README.md · Dev commands: AGENTS.md
#
# API Configuration
REACT_APP_API_URL="https://api.yourdomain.com"
# Mock API (backend/) runs on 3001; Vite proxies /api to it when using npm run dev
VITE_API_URL="http://localhost:8080"
VITE_PROD_URL="https://yourdomain.com"

# Supabase
# Legacy/optional: do not use for URL construction (the app resolves from VITE_SUPABASE_URL).
# VITE_SUPABASE_PROJECT_ID="your_supabase_project_id"
VITE_SUPABASE_URL="https://your_project_id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your_supabase_anon_key"

# Stripe (optional, for payments)
VITE_STRIPE_PUBLISHABLE_KEY="your_stripe_publishable_key"

# App URL (optional, for redirects/links)
VITE_APP_URL="http://localhost:8080"

# Optional: override build label logged as [BUILD VERSION] (defaults to package.json version)
# VITE_APP_VERSION="1.2.3"

# ---------------------------------------------------------------------------
# Optional — local Vitest / tooling only (never use in browser or VITE_* vars)
# ---------------------------------------------------------------------------
# Service role secret from Supabase Dashboard → Project Settings → API.
# Enables admin-style cases in src/tests/edge-functions.test.ts (skipped if unset).
# SUPABASE_SERVICE_ROLE_KEY="your_service_role_key"
#
# RLS E2E against a real project: user credentials + roles — src/tests/rls-test-setup.md
# (those tests use anon key + TEST_USER_* / TEST_ADMIN_* env vars, not the service role)
