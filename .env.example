# API Configuration
REACT_APP_API_URL="https://api.yourdomain.com"
# Mock API (backend/) runs on 3001; Vite proxies /api to it when using npm run dev
VITE_API_URL="http://localhost:8080"
VITE_PROD_URL="https://yourdomain.com"

# Supabase
VITE_SUPABASE_PROJECT_ID="your_supabase_project_id"
VITE_SUPABASE_URL="https://your_project_id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your_supabase_anon_key"

# Stripe (optional, for payments)
VITE_STRIPE_PUBLISHABLE_KEY="your_stripe_publishable_key"

# App URL (optional, for redirects/links)
VITE_APP_URL="http://localhost:8080"

# Payment return page: poll order-lookup while webhook lands
# Default: exponential backoff, ~32s total wait budget (see paymentPollingConfig.ts)
# VITE_PAYMENT_SUCCESS_MAX_WAIT_MS=32000
# VITE_PAYMENT_SUCCESS_POLL_INITIAL_MS=2000
# VITE_PAYMENT_SUCCESS_POLL_MAX_INTERVAL_MS=5000
# VITE_PAYMENT_SUCCESS_POLL_BACKOFF_FACTOR=1.25
# VITE_PAYMENT_SUCCESS_MAX_POLL_STEPS=24
# Legacy flat polling (only if BOTH set and MAX_WAIT_MS unset):
# VITE_PAYMENT_SUCCESS_MAX_POLLS=8
# VITE_PAYMENT_SUCCESS_POLL_INTERVAL_MS=2000
