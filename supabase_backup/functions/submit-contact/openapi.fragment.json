{
  "summary": "Contact form (rate-limited, persisted)",
  "requestBody": {
    "required": true,
    "content": {
      "application/json": {
        "schema": {
          "type": "object",
          "required": ["firstName", "lastName", "email", "subject", "message"],
          "properties": {
            "firstName": { "type": "string" },
            "lastName": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "phone": { "type": "string" },
            "company": { "type": "string" },
            "subject": { "type": "string" },
            "message": { "type": "string" }
          }
        }
      }
    }
  },
  "responses": {
    "200": {
      "description": "success",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "success": { "type": "boolean" },
              "message": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
