# =============================================================================
# Git ignore list
# =============================================================================
# Do not commit build artifacts, secrets, editor files, or generated outputs.
# =============================================================================

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies and build output
node_modules
dist
dist-ssr
*.local

# Environment variables (secrets; never commit)
.env
.env.local
.env.*.local
cypress.env.json

# Cypress E2E artifacts (generated on test failure)
cypress/screenshots/
cypress/videos/
cypress/downloads/

# Editor and IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea
.cursor
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Backup directories (manual or tool-generated)
js-backup/

# TypeScript incremental build artifacts
*.tsbuildinfo

# Test coverage reports (generated by Vitest)
coverage/

# Bun lockfiles (project uses npm; bun.lockb causes update-browserslist-db to fail)
bun.lockb
bun.lock

# Temporary commit message files (used for multi-line commit messages)
docs/commit-msg-*.txt

# Local lint / analysis dumps (do not commit)
lint-current.txt
lint-output.json
scripts/.migration-local-only-versions.txt

# Postman: personal environments with real keys (never commit)
postman/*.local.postman_environment.json
postman/globals.private.json
# Postman desktop workspace exports (not part of repo)
postman/.postman/
postman/postman/

# Supabase CLI local cache
supabase/.temp/

# Edge bundler uses an older Deno and rejects lockfile version 5 (Deno 2).
# Regenerate locally with `deno cache` if needed; do not commit these.
supabase/functions/deno.lock
supabase/functions/*/deno.lock

